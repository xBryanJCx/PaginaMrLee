@model MrLee.Web.Models.RecuperarPasswordClienteVm
@{
    ViewData["Title"] = "Recuperar contraseña";
    Layout = "~/Views/Portal/_LayoutPortal.cshtml";
}
<div class="portal-auth-shell">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="portal-card p-4 p-lg-5">
                    <div class="text-center mb-4">
                        <div style="font-size:2.5rem">🔑</div>
                        <h4 class="mt-2">Recuperar contraseña</h4>
                        <p class="text-muted small">Te enviamos un enlace para restablecer tu contraseña.</p>
                    </div>
                    <form asp-action="RecuperarPassword" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="All" class="alert alert-danger small mb-3"></div>
                        <div class="mb-4">
                            <label class="form-label fw-medium">Correo electrónico</label>
                            <input asp-for="Email" class="form-control" type="email" placeholder="vos@correo.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Enviar enlace</button>
                        <div class="text-center mt-3">
                            <a asp-action="Login" class="small">← Volver al inicio de sesión</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}


