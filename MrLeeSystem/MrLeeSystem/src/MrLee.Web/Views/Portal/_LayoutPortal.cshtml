@{
    var nombre = User.Identity?.Name ?? "";
}
<!doctype html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@(ViewData["Title"] ?? "Mr Lee") – Portal Clientes</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/theme/css/site.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/theme/css/portal.css" rel="stylesheet" asp-append-version="true" />
</head>
<body class="portal-body">

    @if (User.Identity?.IsAuthenticated == true && User.FindFirst("ClienteId") != null)
    {
        <nav class="portal-nav navbar navbar-expand-lg">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" href="/Portal">
                    <img src="~/img/logo.jpeg" alt="Mr Lee" style="height:38px;width:38px;object-fit:cover;border-radius:50%;" />
                    <span class="fw-bold">Mr Lee</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#portalNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="portalNav">
                    <ul class="navbar-nav mx-auto gap-1">
                        <li class="nav-item"><a class="nav-link" asp-controller="Portal" asp-action="Panel">🏠 Inicio</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Portal" asp-action="MisPedidos">📦 Mis pedidos</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Portal" asp-action="Perfil">👤 Mi perfil</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Portal" asp-action="Preferencias">🔔 Notificaciones</a></li>
                    </ul>
                    <div class="d-flex align-items-center gap-2">
                        <span class="navbar-text small">Hola, <strong>@nombre</strong></span>
                        <a asp-controller="Portal" asp-action="Logout" asp-route-returnUrl="/" class="btn btn-sm btn-outline-light">Salir</a>
                    </div>
                </div>
            </div>
        </nav>
    }

    <main class="portal-main">
        @if (TempData["Msg"] != null)
        {
            <div class="container pt-3">
                <div class="alert alert-success border-0 shadow-sm">@TempData["Msg"]</div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="container pt-3">
                <div class="alert alert-danger border-0 shadow-sm">@TempData["Error"]</div>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="portal-footer py-3 text-center small">
        <div class="portal-footer__inner">© @DateTime.Now.Year Mr Lee / Portal de clientes</div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/theme/js/validation-summary.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
