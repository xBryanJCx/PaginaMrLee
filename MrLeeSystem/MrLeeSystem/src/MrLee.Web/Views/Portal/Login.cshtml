@model MrLee.Web.Models.LoginClienteVm
@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = "~/Views/Portal/_LayoutPortal.cshtml";
}
<div class="portal-auth-shell">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="portal-card p-4 p-lg-5">
                    <div class="text-center mb-4">
                        <img src="~/img/logo.jpeg" style="height:56px;width:56px;border-radius:50%;object-fit:cover;" alt="Mr Lee" />
                        <h3 class="mt-3 mb-1">Iniciar sesión</h3>
                        <p class="text-muted small">¿No tenés cuenta? <a asp-action="Registro">Registrate gratis</a></p>
                    </div>
                    <form asp-action="Login" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="All" class="alert alert-danger small mb-3"></div>
                        <div class="mb-3">
                            <label class="form-label fw-medium">Correo</label>
                            <input asp-for="Email" class="form-control" type="email" placeholder="vos@correo.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-medium">Contraseña</label>
                            <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input asp-for="RememberMe" class="form-check-input" type="checkbox" />
                                <label class="form-check-label small">Recordarme</label>
                            </div>
                            <a asp-action="RecuperarPassword" class="small">¿Olvidaste la contraseña?</a>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 py-2">Iniciar sesión</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}
