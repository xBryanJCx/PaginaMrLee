@model MrLee.Web.Models.PerfilClienteVm
@{
    ViewData["Title"] = "Mi perfil";
    Layout = "~/Views/Portal/_LayoutPortal.cshtml";
}
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="portal-card p-4 p-lg-5">
                <h4 class="mb-4" style="color:var(--primary);">👤 Editar mi perfil</h4>
                <form asp-action="Perfil" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="alert alert-danger small mb-3"></div>

                    <h6 class="text-muted mb-3">Datos personales</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Nombre <span class="text-danger">*</span></label>
                            <input asp-for="Nombre" class="form-control" />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Apellido <span class="text-danger">*</span></label>
                            <input asp-for="Apellido" class="form-control" />
                            <span asp-validation-for="Apellido" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Teléfono <span class="text-danger">*</span></label>
                            <input asp-for="Telefono" class="form-control" placeholder="8888-0000" />
                            <span asp-validation-for="Telefono" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Nuevo correo <span class="text-muted small">(opcional)</span></label>
                            <input asp-for="EmailNuevo" class="form-control" type="email" placeholder="nuevo@correo.com" />
                            <div class="form-text">Recibirás un enlace de confirmación.</div>
                        </div>
                    </div>

                    <hr />
                    <h6 class="text-muted mb-3">📍 Dirección de entrega principal</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <label class="form-label fw-medium">Provincia</label>
                            <input asp-for="Provincia" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-medium">Cantón</label>
                            <input asp-for="Canton" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-medium">Distrito</label>
                            <input asp-for="Distrito" class="form-control" />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label fw-medium">Dirección exacta</label>
                            <input asp-for="Direccion" class="form-control" placeholder="100m norte de..." />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-medium">Código postal</label>
                            <input asp-for="CodPostal" class="form-control" />
                        </div>
                    </div>

                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Panel" class="btn btn-outline-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-success">💾 Guardar cambios</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}
