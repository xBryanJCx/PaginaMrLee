@model MrLee.Web.Models.RestablecerPasswordClienteVm
@{
    ViewData["Title"] = "Nueva contraseña";
    Layout = "~/Views/Portal/_LayoutPortal.cshtml";
}
<div class="portal-auth-shell">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="portal-card p-4 p-lg-5">
                    <div class="text-center mb-4">
                        <div style="font-size:2.5rem">🔒</div>
                        <h4 class="mt-2">Nueva contraseña</h4>
                        <p class="text-muted small">Elegí una contraseña segura para tu cuenta.</p>
                    </div>
                    <form asp-action="RestablecerPassword" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Token" />
                        <div asp-validation-summary="All" class="alert alert-danger small mb-3"></div>
                        <div class="mb-3">
                            <label class="form-label fw-medium">Nueva contraseña <span class="text-danger">*</span></label>
                            <input asp-for="PasswordNueva" class="form-control" type="password" />
                            <div class="form-text">Mínimo 8 caracteres, con mayúscula, minúscula, número y símbolo.</div>
                            <span asp-validation-for="PasswordNueva" class="text-danger small"></span>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-medium">Confirmar contraseña <span class="text-danger">*</span></label>
                            <input asp-for="PasswordConf" class="form-control" type="password" />
                            <span asp-validation-for="PasswordConf" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Guardar nueva contraseña</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}
