@{
    ViewData["Title"] = "Verificación de correo";
    Layout = "~/Views/Portal/_LayoutPortal.cshtml";
    var ok = (bool)(ViewBag.Ok ?? false);
}
<div class="portal-auth-shell">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="portal-card p-5 text-center">
                    @if (ok)
                    {
                        <div style="font-size:3rem">✅</div>
                        <h4 class="mt-3">¡Correo verificado!</h4>
                        <p class="text-muted">Tu cuenta está lista. Ya podés iniciar sesión.</p>
                        <a asp-action="Login" class="btn btn-primary mt-2">Iniciar sesión</a>
                    }
                    else
                    {
                        <div style="font-size:3rem">❌</div>
                        <h4 class="mt-3">Enlace inválido</h4>
                        <p class="text-muted">@ViewBag.Error</p>
                        <a asp-action="Login" class="btn btn-outline-primary mt-2">Volver al inicio</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>