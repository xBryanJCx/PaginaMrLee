@model MrLee.Web.Models.Order
@{
    ViewData["Title"] = $"Pedido {Model.TrackingNumber}";
    Layout = "~/Views/Portal/_LayoutPortal.cshtml";
    var pasos = new[] { "Recibido", "En preparación", "En ruta", "Entregado" };
    var paso = (int)Model.Status < 5 ? (int)Model.Status : 4;
}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 style="color:var(--primary);">Pedido <strong>@Model.TrackingNumber</strong></h4>
        <a asp-action="MisPedidos" class="btn btn-outline-primary">← Mis pedidos</a>
    </div>

    @if (Model.Status != MrLee.Web.Models.OrderStatus.Cancelado)
    {
        <div class="portal-card p-4 mb-4">
            <h6 class="mb-3">Progreso de tu pedido</h6>
            <div class="d-flex justify-content-between position-relative">
                <div class="progress-line"></div>
                @foreach (var (p, i) in pasos.Select((p, i) => (p, i + 1)))
                {
                    var activo = i <= paso;
                    <div class="text-center" style="z-index:1;flex:1">
                        <div class="progress-step @(activo ? "active" : "")">@i</div>
                        <div class="small mt-1 @(activo ? "fw-bold" : "text-muted")">@p</div>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-danger">❌ Este pedido fue cancelado.</div>
    }

    <div class="portal-card p-4 mb-4">
        <h6 class="mb-3">Productos</h6>
        <table class="table align-middle mb-0">
            <thead><tr><th>Producto</th><th class="text-end">Cantidad</th><th class="text-end">Precio u.</th><th class="text-end">Subtotal</th></tr></thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Product?.Name</td>
                        <td class="text-end">@item.Quantity.ToString("N2")</td>
                        <td class="text-end">₡ @item.UnitPrice.ToString("N2")</td>
                        <td class="text-end">₡ @((item.Quantity * item.UnitPrice).ToString("N2"))</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="3" class="text-end fw-bold">Total</td>
                    <td class="text-end fw-bold">₡ @Model.Items.Sum(i => i.Quantity * i.UnitPrice).ToString("N2")</td>
                </tr>
            </tfoot>
        </table>
    </div>

    <div class="portal-card p-4">
        <h6 class="mb-2">Datos de entrega</h6>
        <div class="text-muted small">@Model.DeliveryAddress</div>
        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <div class="text-muted small mt-1">Notas: @Model.Notes</div>
        }
    </div>
</div>


