@model MrLee.Web.Models.EmpleadoListVm
@{
    ViewData["Title"] = "Empleados";
}

<div class="section-panel mb-4">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-md-4">
            <label class="form-label">Buscar</label>
            <input type="text" class="form-control" name="criterio" value="@Model.Criterio" placeholder="Nombre, código, identificación..." />
        </div>
        <div class="col-md-2">
            <label class="form-label">Estado</label>
            <select class="form-select" name="estado">
                <option value="">Todos</option>
                <option value="ACTIVO" selected="@(Model.Estado == MrLee.Web.Models.EstadoEmpleado.ACTIVO)">Activo</option>
                <option value="INACTIVO" selected="@(Model.Estado == MrLee.Web.Models.EstadoEmpleado.INACTIVO)">Inactivo</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label">Sucursal</label>
            <select class="form-select" name="sucursalId">
                <option value="">Todas</option>
                @foreach (var s in Model.Sucursales)
                {
                    <option value="@s.Value" selected="@(Model.SucursalId?.ToString() == s.Value)">@s.Text</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Ordenar por</label>
            <select class="form-select" name="ordenarPor">
                <option value="NOMBRE" selected="@(Model.OrdenarPor == "NOMBRE")">Nombre</option>
                <option value="FECHA_INGRESO" selected="@(Model.OrdenarPor == "FECHA_INGRESO")">Fecha ingreso</option>
            </select>
        </div>
        <div class="col-md-1 d-grid">
            <button class="btn btn-info text-white">🔍 Buscar</button>
        </div>
    </form>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="h4 m-0">Empleados <span class="badge bg-secondary ms-1">@Model.TotalItems</span></h2>
    <div class="d-flex gap-2">
        <a asp-action="Exportar"
           asp-route-criterio="@Model.Criterio"
           asp-route-estado="@Model.Estado"
           asp-route-sucursalId="@Model.SucursalId"
           class="btn btn-outline-success btn-sm">⬇ Exportar CSV</a>
        <a asp-action="Crear" class="btn btn-success">&#43; Nuevo empleado</a>
    </div>
</div>

<div class="table-responsive section-panel">
    <table class="table table-hover align-middle mb-0">
        <thead>
            <tr>
                <th>Código</th>
                <th>Nombre</th>
                <th>Identificación</th>
                <th>Puesto</th>
                <th>Sucursal</th>
                <th>Ingreso</th>
                <th>Estado</th>
                <th style="width:200px"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in Model.Items)
            {
                <tr>
                    <td><strong>@e.Codigo</strong></td>
                    <td>@e.Nombre @e.Apellido</td>
                    <td>@e.Identificacion</td>
                    <td>@e.Puesto?.Nombre</td>
                    <td>@e.Sucursal?.Nombre</td>
                    <td>@e.FechaIngreso.ToString("dd/MM/yyyy")</td>
                    <td>
                        @if (e.Estado == MrLee.Web.Models.EstadoEmpleado.ACTIVO)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {

                            <span class="badge bg-secondary">Inactivo</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Detalle" asp-route-id="@e.Id" class="btn btn-sm btn-primary">Ver</a>
                        <a asp-action="Editar" asp-route-id="@e.Id" class="btn btn-sm btn-warning text-dark">✏️ Editar</a>
                        <a asp-action="CambiarEstado" asp-route-id="@e.Id" class="btn btn-sm btn-outline-secondary">⚙ Estado</a>
                    </td>
                </tr>
            }
            @if (!Model.Items.Any())
            {
                <tr><td colspan="8" class="text-center text-muted py-4">No se encontraron empleados.</td></tr>
            }
        </tbody>
    </table>
</div>

@if (Model.TotalPaginas > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= Model.TotalPaginas; i++)
            {
                <li class="page-item @(i == Model.Pagina ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-criterio="@Model.Criterio"
                       asp-route-estado="@Model.Estado"
                       asp-route-sucursalId="@Model.SucursalId"
                       asp-route-ordenarPor="@Model.OrdenarPor"
                       asp-route-pagina="@i">@i</a>
                </li>
            }
        </ul>
    </nav>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mt-3">@TempData["Error"]</div>
}
