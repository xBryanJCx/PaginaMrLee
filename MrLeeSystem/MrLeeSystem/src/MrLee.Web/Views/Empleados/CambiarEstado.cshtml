@model MrLee.Web.Models.CambioEstadoVm
@{
    ViewData["Title"] = "Cambiar estado";
    var inactivar = Model.NuevoEstado == MrLee.Web.Models.EstadoEmpleado.INACTIVO;
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="section-panel">
            <h5 class="mb-1">@Model.NombreCompleto</h5>
            <p class="text-muted mb-4">
                Estado actual: <strong>@Model.EstadoActual</strong> →
                Nuevo estado: <strong class="@(inactivar ? "text-danger" : "text-success")">@Model.NuevoEstado</strong>
            </p>

            <form asp-action="CambiarEstado" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="EmpleadoId" />
                <input type="hidden" asp-for="EstadoActual" />
                <input type="hidden" asp-for="NuevoEstado" />
                <input type="hidden" asp-for="NombreCompleto" />

                <div asp-validation-summary="All" class="alert alert-danger mb-3"></div>

                <div class="mb-3">
                    <label class="form-label fw-medium">Motivo <span class="text-danger">*</span></label>
                    <textarea asp-for="MotivoCambio" class="form-control" rows="3"
                              placeholder="@(inactivar ? "Ej: Renuncia voluntaria, vencimiento contrato..." : "Ej: Reingreso aprobado por gerencia...")"></textarea>
                    <span asp-validation-for="MotivoCambio" class="text-danger small"></span>
                </div>

                @if (inactivar)
                {
                    <div class="mb-4">
                        <label class="form-label fw-medium">Fecha de salida</label>
                        <input asp-for="FechaSalida" class="form-control" type="date" />
                    </div>
                }

                <div class="d-flex gap-2 justify-content-end">
                    <a asp-action="Detalle" asp-route-id="@Model.EmpleadoId" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn @(inactivar ? "btn-danger" : "btn-success")">
                        @(inactivar ? "⛔ Inactivar" : "✅ Reactivar")
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
