@model List<MrLee.Web.Models.Incapacidad>
@{
    ViewData["Title"] = "Incapacidades";
    var emp = ViewBag.Empleado as MrLee.Web.Models.Empleado;
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="mb-0">Incapacidades — @emp?.Nombre @emp?.Apellido</h4>
    </div>
    <a asp-action="Crear" asp-route-empleadoId="@emp?.Id" class="btn btn-success">&#43; Nueva incapacidad</a>
</div>
<div class="section-panel">
    <table class="table table-hover align-middle mb-0">
        <thead>
            <tr><th>Período</th><th>Días</th><th>Centro médico</th><th>Nº orden</th><th>Tipo doc.</th><th>Estado</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var i in Model)
            {
                var dias = (int)(i.FechaFin - i.FechaInicio).TotalDays + 1;
                <tr>
                    <td>@i.FechaInicio.ToString("dd/MM/yyyy") – @i.FechaFin.ToString("dd/MM/yyyy")</td>
                    <td>@dias</td>
                    <td>@i.CentroMedico</td>
                    <td>@i.NumeroOrden</td>
                    <td>@i.TipoDocumento</td>
                    <td>
                        @switch (i.Estado)
                        {
                            case MrLee.Web.Models.EstadoIncapacidad.REGISTRADA:
                                <span class="badge bg-warning text-dark">Registrada</span>
                                ; break;
                            case MrLee.Web.Models.EstadoIncapacidad.VIGENTE:

                                <span class="badge bg-primary">Vigente</span>
                                ; break;
                            case MrLee.Web.Models.EstadoIncapacidad.FINALIZADA:

                                <span class="badge bg-secondary">Finalizada</span>
                                ; break;
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Editar" asp-route-id="@i.Id" class="btn btn-sm btn-warning text-dark">✏️ Editar</a>
                        @if (!string.IsNullOrEmpty(i.DocumentoUrl))
                        {
                            <a href="@i.DocumentoUrl" target="_blank" class="btn btn-sm btn-outline-info">📄 Ver doc.</a>
                        }
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="7" class="text-center text-muted py-4">Sin registros.</td></tr>
            }
        </tbody>
    </table>
</div>
<div class="mt-3">
    <a asp-controller="Empleados" asp-action="Detalle" asp-route-id="@emp?.Id" class="btn btn-outline-secondary">← Volver</a>
</div>

