@model MrLee.Web.Models.DireccionFormVm
@{
    var esEdicion = Model.DireccionId.HasValue; ViewData["Title"] = esEdicion ? "Editar dirección" : "Nueva dirección";
}
<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="section-panel">
            <h5 class="mb-1">@Model.NombreEmpleado</h5>
            <p class="text-muted small mb-4">@ViewData["Title"]</p>
            <form asp-action="@(esEdicion ? "EditarDireccion" : "CrearDireccion")" method="post">
                @Html.AntiForgeryToken()
                @if (esEdicion)
                {
                    <input type="hidden" asp-for="DireccionId" />
                }
                <input type="hidden" asp-for="EmpleadoId" />
                <input type="hidden" asp-for="NombreEmpleado" />
                <div asp-validation-summary="All" class="alert alert-danger mb-3"></div>
                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label class="form-label fw-medium">Tipo</label>
                        <select asp-for="Tipo" class="form-select" asp-items="Html.GetEnumSelectList<MrLee.Web.Models.TipoDireccion>()"></select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-medium">Provincia <span class="text-danger">*</span></label>
                        <input asp-for="Provincia" class="form-control" />
                        <span asp-validation-for="Provincia" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-medium">Cantón <span class="text-danger">*</span></label>
                        <input asp-for="Canton" class="form-control" />
                        <span asp-validation-for="Canton" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-medium">Distrito <span class="text-danger">*</span></label>
                        <input asp-for="Distrito" class="form-control" />
                        <span asp-validation-for="Distrito" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-medium">Código postal</label>
                        <input asp-for="CodigoPostal" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-medium">Dirección exacta <span class="text-danger">*</span></label>
                        <textarea asp-for="Direccion" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="Direccion" class="text-danger small"></span>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-medium">Latitud</label>
                        <input asp-for="Lat" class="form-control" type="number" step="0.000001" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-medium">Longitud</label>
                        <input asp-for="Lon" class="form-control" type="number" step="0.000001" />
                    </div>
                    <div class="col-md-6 d-flex align-items-end">
                        <div class="form-check">
                            <input asp-for="EsPrincipal" class="form-check-input" type="checkbox" />
                            <label class="form-check-label">Marcar como dirección principal</label>
                        </div>
                    </div>
                </div>
                <div class="d-flex gap-2 justify-content-end">
                    <a asp-action="Index" asp-route-empleadoId="@Model.EmpleadoId" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-success">💾 Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}
