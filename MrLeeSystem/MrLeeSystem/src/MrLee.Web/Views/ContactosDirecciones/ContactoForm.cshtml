@model MrLee.Web.Models.ContactoFormVm
@{
    var esEdicion = Model.ContactoId.HasValue; ViewData["Title"] = esEdicion ? "Editar contacto" : "Nuevo contacto";
}
<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="section-panel">
            <h5 class="mb-1">@Model.NombreEmpleado</h5>
            <p class="text-muted small mb-4">Contacto de emergencia</p>
            <form asp-action="@(esEdicion ? "EditarContacto" : "CrearContacto")" method="post">
                @Html.AntiForgeryToken()
                @if (esEdicion)
                {
                    <input type="hidden" asp-for="ContactoId" />
                }
                <input type="hidden" asp-for="EmpleadoId" />
                <input type="hidden" asp-for="NombreEmpleado" />
                <div asp-validation-summary="All" class="alert alert-danger mb-3"></div>
                <div class="row g-3 mb-3">
                    <div class="col-md-8">
                        <label class="form-label fw-medium">Nombre <span class="text-danger">*</span></label>
                        <input asp-for="Nombre" class="form-control" />
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-medium">Parentesco</label>
                        <select asp-for="Parentesco" class="form-select" asp-items="Html.GetEnumSelectList<MrLee.Web.Models.Parentesco>()"></select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-medium">Teléfono <span class="text-danger">*</span></label>
                        <input asp-for="Telefono" class="form-control" placeholder="8888-0000" />
                        <span asp-validation-for="Telefono" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-medium">Teléfono alternativo</label>
                        <input asp-for="TelefonoAlt" class="form-control" placeholder="Opcional" />
                    </div>
                    <div class="col-md-8">
                        <label class="form-label fw-medium">Correo</label>
                        <input asp-for="Email" class="form-control" type="email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <div class="form-check">
                            <input asp-for="EsPrincipal" class="form-check-input" type="checkbox" />
                            <label class="form-check-label">Contacto principal</label>
                        </div>
                    </div>
                </div>
                <div class="d-flex gap-2 justify-content-end">
                    <a asp-action="Index" asp-route-empleadoId="@Model.EmpleadoId" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-success">💾 Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}