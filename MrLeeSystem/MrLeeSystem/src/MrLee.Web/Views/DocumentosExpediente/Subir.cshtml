@model MrLee.Web.Models.DocumentoFormVm
@{
    ViewData["Title"] = "Subir documento";
}
<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="section-panel">
            <h5 class="mb-1">@Model.NombreEmpleado</h5>
            <p class="text-muted small mb-4">Subir documento al expediente</p>
            <form asp-action="Subir" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="EmpleadoId" />
                <input type="hidden" asp-for="NombreEmpleado" />
                <div asp-validation-summary="All" class="alert alert-danger mb-3"></div>
                <div class="mb-3">
                    <label class="form-label fw-medium">Tipo de documento <span class="text-danger">*</span></label>
                    <select asp-for="DocumentoTipo" class="form-select"
                            asp-items="Html.GetEnumSelectList<MrLee.Web.Models.TipoDocumentoExpediente>()"></select>
                </div>
                <div class="mb-4">
                    <label class="form-label fw-medium">Archivo <span class="text-danger">*</span></label>
                    <input asp-for="Archivo" class="form-control" type="file" accept=".pdf,.jpg,.jpeg,.png,.docx" />
                    <div class="form-text">Formatos: PDF, JPG, PNG, DOCX. Máximo 10 MB.</div>
                    <span asp-validation-for="Archivo" class="text-danger small"></span>
                </div>
                <div class="d-flex gap-2 justify-content-end">
                    <a asp-action="Index" asp-route-empleadoId="@Model.EmpleadoId" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-success">⬆ Subir</button>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}