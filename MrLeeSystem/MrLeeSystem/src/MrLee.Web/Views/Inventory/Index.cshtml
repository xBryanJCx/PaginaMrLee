@model List<MrLee.Web.Models.Product>
@{
    ViewData["Title"] = "Inventario";
    var hasQuery = !string.IsNullOrWhiteSpace(ViewBag.Query as string);
}

<div class="d-flex justify-content-between align-items-center mb-3">
  <h2 class="h4 m-0">Inventario</h2>
  <a class="btn btn-primary" asp-action="Create">Nuevo producto</a>
</div>

<form class="row g-2 mb-3" method="get">
  <div class="col-md-6">
    <input name="q" value="@ViewBag.Query" class="form-control" placeholder="Buscar por SKU o nombre..." />
  </div>
  <div class="col-md-2">
    <button class="btn btn-info text-white w-100" type="submit">Buscar</button>
  </div>
</form>

@if (Model.Any())
{
  <div class="table-responsive section-panel">
    <table class="table table-striped table-sm align-middle mb-0">
      <thead>
        <tr>
          <th>SKU</th>
          <th>Producto</th>
          <th>Unidad</th>
          <th class="text-end">Precio</th>
          <th class="text-end">Existencia</th>
          <th>Estado</th>
          <th style="width: 240px;"></th>
        </tr>
      </thead>
      <tbody>
      @foreach (var p in Model)
      {
        <tr>
          <td>@p.Sku</td>
          <td>@p.Name</td>
          <td>@p.Unit</td>
          <td class="text-end">@p.UnitPrice.ToString("N2")</td>
          <td class="text-end">@p.CurrentStock.ToString("N2")</td>
          <td>
            @if (p.IsActive) { <span class="badge bg-success">Activo</span> } else { <span class="badge bg-secondary">Inactivo</span> }
          </td>
          <td class="text-end">
            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@p.Id">Editar</a>
            <a class="btn btn-sm btn-outline-info" asp-action="Movements" asp-route-id="@p.Id">Movimientos</a>
          </td>
        </tr>
      }
      </tbody>
    </table>
  </div>
}
else
{
  @if (hasQuery)
  {
    <partial name="_EmptyMessage" model='new EmptyMessageVm
    {
        Variant = "search",
        Title = "No encontramos productos",
        Message = "No hay productos que coincidan con tu busqueda actual.",
        SupportText = "Prueba con otro SKU o nombre, o limpia la busqueda para ver todo el inventario.",
        ActionText = "Limpiar busqueda",
        ActionUrl = Url.Action("Index")!
    }' />
  }
  else
  {
    <partial name="_EmptyMessage" model='new EmptyMessageVm
    {
        Title = "Sin productos registrados",
        Message = "Todavia no hay productos cargados en inventario.",
        ActionText = "Nuevo producto",
        ActionUrl = Url.Action("Create")!
    }' />
  }
}
