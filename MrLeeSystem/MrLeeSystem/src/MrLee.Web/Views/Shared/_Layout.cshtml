@{
    var title = ViewData["Title"]?.ToString() ?? "Mr Lee";
    var controllerName = ViewContext.RouteData.Values["controller"]?.ToString();
    var isAuthenticated = User?.Identity?.IsAuthenticated ?? false;
    var isAccountPage = string.Equals(controllerName, "Account", StringComparison.OrdinalIgnoreCase) && !isAuthenticated;
    var bodyClass = isAccountPage ? "account-body app-shell" : "app-body app-shell";
    var mainClass = isAccountPage ? "account-page app-main" : "container py-4 page-shell app-main";
}
<!doctype html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title - Mr Lee</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/theme/css/site.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/theme/css/account.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/theme/css/site-overrides.css" rel="stylesheet" asp-append-version="true" />
</head>
<body class="@bodyClass">
@if (!isAccountPage)
{
    <nav class="navbar navbar-expand-lg main-navbar">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-3" asp-controller="Home" asp-action="Index">
                <img src="~/img/logo.jpeg" alt="Mr Lee" style="height:42px; width:42px; object-fit:cover; border-radius:50%; border:2px solid rgba(255,255,255,.2);" />
                <div>
                    <div class="fw-bold lh-1">Mr Lee System</div>
                    <small class="opacity-75">Panel administrativo</small>
                </div>
            </a>
            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMain">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Inicio</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Orders" asp-action="Index">Pedidos</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Inventory" asp-action="Index">Inventario</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Users" asp-action="Index">Usuarios</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="OperatingIncome" asp-action="Index">Ingresos</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Users" asp-action="Audit">Bitacora</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Empleados" asp-action="Index">Empleados</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Vacaciones" asp-action="Pendientes">Vacaciones</a></li>
                </ul>
                <div class="d-flex align-items-center gap-2">
                    @if (isAuthenticated)
                    {
                        <span class="navbar-text small">Hola, <strong>@(User?.Identity?.Name ?? "Usuario")</strong></span>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-app-soft-danger" type="submit">Salir</button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </nav>

    <section class="hero-banner">
        <div class="container">
            <div class="row align-items-end g-4">
                <div class="col-lg-9">
                    <div class="hero-subtitle">MR LEE SYSTEM</div>
                    <h1 class="display-5 mb-3">@title</h1>
                    <p class="lead mb-0">Gestión integral de la panadería con control total sobre pedidos, inventario, ingresos y equipo de trabajo desde un único panel administrativo.</p>
                </div>
            </div>
        </div>
    </section>
}

<main class="@mainClass">
    @if (TempData["Msg"] != null)
    {
        <div class="alert alert-success shadow-sm border-0 @(isAccountPage ? "account-alert" : "")">@TempData["Msg"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger shadow-sm border-0 @(isAccountPage ? "account-alert" : "")">@TempData["Error"]</div>
    }
    @RenderBody()
</main>

@if (!isAccountPage)
{
    <footer class="footer footer-sticky text-center py-3">
        <div class="container-fluid">
            <small>&copy; 2024 Mr Lee System. Todos los derechos reservados.</small>
        </div>
    </footer>
}

<partial name="_ConfirmActionModal" />

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/theme/js/confirm-actions.js" asp-append-version="true"></script>
<script src="~/theme/js/validation-summary.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
