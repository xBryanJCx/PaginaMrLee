@{
    var title = ViewData["Title"]?.ToString() ?? "Mr Lee";
    var controllerName = ViewContext.RouteData.Values["controller"]?.ToString();
    var isAccountPage = string.Equals(controllerName, "Account", StringComparison.OrdinalIgnoreCase)
        && !(User?.Identity?.IsAuthenticated ?? false);
}
<!doctype html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title - Mr Lee</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/theme/css/site.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>
    @if (!isAccountPage)
    {
        <div class="container-fluid top-bar py-2 d-none d-lg-block">
            <div class="container d-flex justify-content-between align-items-center">
                <div>Sistema de gestión integral para pedidos, inventario y seguridad.</div>
                <div class="d-flex gap-3">
                    <a asp-controller="Orders" asp-action="Index">Pedidos</a>
                    <a asp-controller="Inventory" asp-action="Index">Inventario</a>
                    <a asp-controller="Users" asp-action="Index">Usuarios</a>
                    <a asp-controller="OperatingIncome" asp-action="Index">Ingresos</a>
                </div>
            </div>
        </div>

        <nav class="navbar navbar-expand-lg main-navbar sticky-top">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-3" asp-controller="Home" asp-action="Index">
                    <img src="~/img/logo.jpeg" alt="Mr Lee" style="height:42px; width:42px; object-fit:cover; border-radius:50%; border:2px solid rgba(255,255,255,.2);" />
                    <div>
                        <div class="fw-bold lh-1">Mr Lee System</div>
                        <small class="opacity-75">Panel administrativo</small>
                    </div>
                </a>
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navMain">
                    <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Inicio</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Orders" asp-action="Index">Pedidos</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Inventory" asp-action="Index">Inventario</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Users" asp-action="Index">Usuarios</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="OperatingIncome" asp-action="Index">Ingresos</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Users" asp-action="Audit">Bitácora</a></li>
                    </ul>
                    <div class="d-flex align-items-center gap-2">
                        @if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            <span class="navbar-text small">Hola, <strong>@User.Identity!.Name</strong></span>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-primary btn-sm" type="submit">Salir</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </nav>

        <section class="hero-banner">
            <div class="container">
                <div class="row justify-content-between align-items-end g-4">
                    <div class="col-lg-8">
                        <div class="hero-subtitle">Plantilla visual integrada</div>
                        <h1 class="display-5 mb-3">@title</h1>
                        <p class="lead mb-0">Diseño renovado con la identidad del template bakery, adaptado al flujo administrativo de Mr Lee.</p>
                    </div>
                    <div class="col-lg-4 text-lg-end">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb justify-content-lg-end mb-0">
                                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Inicio</a></li>
                                <li class="breadcrumb-item active" aria-current="page">@title</li>
                            </ol>
                        </nav>
                    </div>
                </div>
            </div>
        </section>
    }

    <main class="container py-4 page-shell">
        @if (TempData["Msg"] != null)
        {
            <div class="alert alert-success shadow-sm border-0">@TempData["Msg"]</div>
        }
        @RenderBody()
    </main>

    @if (!isAccountPage)
    {
        <footer class="footer mt-5 py-4">
            <div class="container d-flex flex-column flex-lg-row justify-content-between gap-3">
                <div>
                    <h5 class="mb-1">Mr Lee System</h5>
                    <div>Gestión de pedidos, inventario, usuarios y auditoría con una interfaz moderna.</div>
                </div>
                <div class="text-lg-end">
                    <strong>Módulos:</strong> Pedidos · Inventario · Ingresos · Usuarios · Bitácora
                </div>
            </div>
        </footer>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
