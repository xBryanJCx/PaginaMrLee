@model OperatingIncomeEditVm
@{
    var action = ViewData["FormAction"]?.ToString() ?? "Create";
    var button = ViewData["FormButton"]?.ToString() ?? "Guardar";
}

<div class="section-panel">
    <form asp-action="@action" method="post" enctype="multipart/form-data" class="row g-3">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="col-md-3">
            <label asp-for="IncomeDate" class="form-label">Fecha</label>
            <input asp-for="IncomeDate" class="form-control" type="date" />
            <span asp-validation-for="IncomeDate" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="Type" class="form-label">Tipo</label>
            <select asp-for="Type" asp-items="Html.GetEnumSelectList<OperatingIncomeType>()" class="form-select"></select>
        </div>
        <div class="col-md-3">
            <label asp-for="Category" class="form-label">Categoria</label>
            <input asp-for="Category" class="form-control" />
            <span asp-validation-for="Category" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="Amount" class="form-label">Monto</label>
            <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0.01" />
            <span asp-validation-for="Amount" class="text-danger small"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="SourceName" class="form-label">Origen / cliente / caja</label>
            <input asp-for="SourceName" class="form-control" />
            <span asp-validation-for="SourceName" class="text-danger small"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Reference" class="form-label">Referencia</label>
            <input asp-for="Reference" class="form-control" />
            <span asp-validation-for="Reference" class="text-danger small"></span>
        </div>

        <div class="col-12">
            <label asp-for="Description" class="form-label">Descripcion</label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Description" class="text-danger small"></span>
        </div>

        <div class="col-12">
            <label class="form-label">Comprobantes</label>
            <input type="file" class="form-control" name="files" multiple />
            <div class="form-text">Puede adjuntar imagenes o PDF como respaldo del ingreso.</div>
        </div>

        <div class="col-12">
            <div class="app-split-actions">
                <div class="app-action-group">
                    <a asp-action="Index" class="btn btn-outline-secondary">Volver al listado</a>
                </div>
                <div class="app-action-group app-action-group--right">
                    <button type="submit" class="btn btn-primary">@button</button>
                </div>
            </div>
        </div>
    </form>
</div>
