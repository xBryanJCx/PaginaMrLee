@model List<AccountingPeriod>
@{
    ViewData["Title"] = "Periodos contables";
}

<section class="section-panel app-page-header mb-4">
    <div class="app-title-row">
        <div>
            <div class="app-eyebrow mb-2">Gestion contable</div>
            <h2 class="h2 mb-2">Periodos contables</h2>
            <p class="app-page-copy mb-0">Administra cierres y reaperturas de periodos para proteger la informacion financiera registrada.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Volver a ingresos</a>
    </div>
</section>

<section class="section-panel mb-4">
    <h3 class="h5 mb-3">Cerrar periodo</h3>
    <form asp-action="ClosePeriod" method="post" class="row g-3 align-items-end">
        @Html.AntiForgeryToken()
        <div class="col-md-3">
            <label class="form-label">A&ntilde;o</label>
            <input type="number" name="Year" class="form-control" value="@DateTime.Today.Year" min="2020" max="2100" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Mes</label>
            <input type="number" name="Month" class="form-control" value="@DateTime.Today.Month" min="1" max="12" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Notas</label>
            <input type="text" name="Notes" class="form-control" placeholder="Cierre mensual" />
        </div>
        <div class="col-md-2 d-grid">
            <button class="btn btn-primary" type="submit">Cerrar</button>
        </div>
    </form>
</section>

<section class="section-panel">
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Periodo</th>
                        <th>Estado</th>
                        <th>Cerrado por</th>
                        <th>Fecha</th>
                        <th>Notas</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>@p.Year-@p.Month.ToString("00")</td>
                        <td>
                            @if (p.Status == AccountingPeriodStatus.Cerrado)
                            {
                                <span class="app-status-badge app-status-badge--voided">Cerrado</span>
                            }
                            else
                            {
                                <span class="app-status-badge app-status-badge--active">Abierto</span>
                            }
                        </td>
                        <td>@(string.IsNullOrWhiteSpace(p.ClosedByEmail) ? "Sin registro" : p.ClosedByEmail)</td>
                        <td>@(p.ClosedAtUtc?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                        <td>@(string.IsNullOrWhiteSpace(p.Notes) ? "Sin notas" : p.Notes)</td>
                        <td class="text-end">
                            @if (p.Status == AccountingPeriodStatus.Cerrado)
                            {
                                <form asp-action="ReopenPeriod" asp-route-id="@p.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-success" type="submit">Reabrir</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <partial name="_EmptyMessage" model='new EmptyMessageVm
        {
            Title = "Sin periodos registrados",
            Message = "Todavia no se han generado cierres contables para mostrar en este listado."
        }' />
    }
</section>
