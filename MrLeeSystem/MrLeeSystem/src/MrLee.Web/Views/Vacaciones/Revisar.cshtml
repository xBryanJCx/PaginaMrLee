@model MrLee.Web.Models.RevisionVacacionVm
@{
    ViewData["Title"] = "Revisar solicitud";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="section-panel">
            <h5 class="mb-1">@Model.NombreEmpleado</h5>
            <p class="text-muted mb-4">
                @Model.FechaInicio.ToString("dd/MM/yyyy") al @Model.FechaFin.ToString("dd/MM/yyyy")
                — <strong>@Model.DiasSolicitados día(s)</strong>
            </p>

            <form asp-action="Revisar" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="SolicitudId" />
                <input type="hidden" asp-for="NombreEmpleado" />
                <input type="hidden" asp-for="FechaInicio" />
                <input type="hidden" asp-for="FechaFin" />
                <input type="hidden" asp-for="DiasSolicitados" />

                <div asp-validation-summary="All" class="alert alert-danger mb-3"></div>

                <div class="mb-3">
                    <label class="form-label fw-medium">Decisión <span class="text-danger">*</span></label>
                    <select asp-for="Decision" class="form-select">
                        <option value="2">✅ Aprobar</option>
                        <option value="3">❌ Rechazar</option>
                    </select>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-medium">Motivo de rechazo <span class="text-muted">(requerido si rechaza)</span></label>
                    <textarea asp-for="MotivoRechazo" class="form-control" rows="3" maxlength="300"></textarea>
                    <span asp-validation-for="MotivoRechazo" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2 justify-content-end">
                    <a asp-action="Pendientes" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-success">Guardar decisión</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}