@model List<MrLee.Web.Models.SolicitudVacacion>
@{
    ViewData["Title"] = "Historial de vacaciones";
    var emp = ViewBag.Empleado as MrLee.Web.Models.Empleado;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="mb-0">@emp?.Nombre @emp?.Apellido</h4>
        <div class="text-muted small">Saldo disponible: <strong>@emp?.DiasVacacionDisponibles día(s)</strong></div>
    </div>
    <a asp-action="Solicitar" asp-route-empleadoId="@emp?.Id" class="btn btn-success">🏖 Nueva solicitud</a>
</div>

<div class="section-panel mb-3">
    <form method="get" class="row g-2 align-items-end">
        <input type="hidden" name="empleadoId" value="@emp?.Id" />
        <div class="col-md-4">
            <label class="form-label">Desde</label>
            <input type="date" class="form-control" name="desde" value="@ViewBag.Desde?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Hasta</label>
            <input type="date" class="form-control" name="hasta" value="@ViewBag.Hasta?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-md-2">
            <button class="btn btn-info text-white w-100">🔍 Filtrar</button>
        </div>
    </form>
</div>

<div class="section-panel">
    <table class="table table-hover align-middle mb-0">
        <thead>
            <tr>
                <th>#</th>
                <th>Fecha inicio</th>
                <th>Fecha fin</th>
                <th>Días</th>
                <th>Tipo</th>
                <th>Estado</th>
                <th>Observaciones</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model)
            {
                <tr>
                    <td>@s.Id</td>
                    <td>@s.FechaInicio.ToString("dd/MM/yyyy")</td>
                    <td>@s.FechaFin.ToString("dd/MM/yyyy")</td>
                    <td>@s.DiasSolicitados</td>
                    <td>@s.TipoDia</td>
                    <td>
                        @switch (s.Estado)
                        {
                            case MrLee.Web.Models.EstadoSolicitudVacacion.SOLICITADA:
                                <span class="badge bg-warning text-dark">Solicitada</span>
                                ; break;
                            case MrLee.Web.Models.EstadoSolicitudVacacion.APROBADA:
                                <span class="badge bg-success">Aprobada</span>
                                ; break;
                            case MrLee.Web.Models.EstadoSolicitudVacacion.RECHAZADA:
                                <span class="badge bg-danger">Rechazada</span>
                                ; break;
                            case MrLee.Web.Models.EstadoSolicitudVacacion.CANCELADA:
                                <span class="badge bg-secondary">Cancelada</span>
                                ; break;
                        }
                    </td>
                    <td class="small">
                        @s.Observaciones
                        @if (!string.IsNullOrEmpty(s.MotivoRechazo))
                        {
                            <div class="text-danger">Rechazo: @s.MotivoRechazo</div>
                        }
                    </td>
                    <td>
                        @if (s.Estado == MrLee.Web.Models.EstadoSolicitudVacacion.SOLICITADA && s.FechaInicio > DateTime.Today)
                        {
                            <form asp-action="Cancelar" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="solicitudId" value="@s.Id" />
                                <input type="hidden" name="empleadoId" value="@emp?.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('¿Cancelar esta solicitud?')">
                                    Cancelar
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="8" class="text-center text-muted py-4">No hay solicitudes en este rango.</td></tr>
            }
        </tbody>
    </table>
</div>

<div class="mt-3">
    <a asp-controller="Empleados" asp-action="Detalle" asp-route-id="@emp?.Id" class="btn btn-outline-secondary">← Volver al empleado</a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mt-3">@TempData["Error"]</div>
}