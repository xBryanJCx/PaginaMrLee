@model List<MrLee.Web.Models.AppUser>
@{
    ViewData["Title"] = "Usuarios";
    var hasQuery = !string.IsNullOrWhiteSpace(ViewBag.Query as string);
    var currentUserId = int.TryParse(User.FindFirst("UserId")?.Value, out var parsedUserId) ? parsedUserId : (int?)null;
}

<div class="d-flex justify-content-between align-items-center mb-3">
  <h2 class="h4 m-0">Usuarios</h2>
  <a class="btn btn-primary" asp-action="Create">Nuevo usuario</a>
</div>

<form class="row g-2 mb-3" method="get">
  <div class="col-md-6">
    <input name="q" value="@ViewBag.Query" class="form-control" placeholder="Buscar por nombre o correo..." />
  </div>
  <div class="col-md-2">
      <button class="btn btn-info text-white w-100" type="submit">Buscar</button>
  </div>
</form>

@if (Model.Any())
{
  <div class="table-responsive section-panel">
    <table class="table table-striped table-sm align-middle mb-0">
      <thead>
        <tr>
          <th>Nombre</th>
          <th>Correo</th>
          <th>Rol</th>
          <th>Estado</th>
          <th style="width: 280px;"></th>
        </tr>
      </thead>
      <tbody>
      @foreach (var u in Model)
      {
        <tr>
          <td>@u.FullName</td>
          <td>@u.Email</td>
          <td>@u.Role?.Name</td>
          <td>
            @if (u.IsActive) { <span class="badge bg-success">Activo</span> } else { <span class="badge bg-secondary">Inactivo</span> }
          </td>
          <td class="text-end">
            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@u.Id">Editar</a>
            <a class="btn btn-sm btn-outline-warning" asp-action="ResetPassword" asp-route-id="@u.Id">Reset pass</a>

            <form asp-action="ToggleActive" asp-route-id="@u.Id" method="post" class="d-inline">
              @Html.AntiForgeryToken()
              <button class="btn btn-sm btn-outline-warning text-dark" type="submit">Activar/Desactivar</button>
            </form>

            @if (currentUserId != u.Id)
            {
              <form asp-action="Delete"
                    asp-route-id="@u.Id"
                    method="post"
                    class="d-inline js-confirm-form"
                    data-confirm-title="&#191;Est&aacute;s seguro?"
                    data-confirm-message="Esta acci&oacute;n no se puede deshacer."
                    data-confirm-button="Eliminar"
                    data-confirm-button-class="btn-danger">
                @Html.AntiForgeryToken()
                <button class="btn btn-sm btn-outline-danger" type="submit">Eliminar</button>
              </form>
            }
          </td>
        </tr>
      }
      </tbody>
    </table>
  </div>
}
else
{
  @if (hasQuery)
  {
    <partial name="_EmptyMessage" model='new EmptyMessageVm
    {
        Variant = "search",
        Title = "No encontramos resultados",
        Message = "No hay usuarios que coincidan con tu busqueda actual.",
        SupportText = "Prueba con otro nombre o correo, o limpia la busqueda para ver todos los registros.",
        ActionText = "Limpiar busqueda",
        ActionUrl = Url.Action("Index")!
    }' />
  }
  else
  {
    <partial name="_EmptyMessage" model='new EmptyMessageVm
    {
        Title = "Sin usuarios registrados",
        Message = "Todavia no hay usuarios creados en el sistema.",
        ActionText = "Nuevo usuario",
        ActionUrl = Url.Action("Create")!
    }' />
  }
}
