@model List<MrLee.Web.Models.MovimientoLaboral>
@{
    ViewData["Title"] = "Historial de movimientos";
    var emp = ViewBag.Empleado as MrLee.Web.Models.Empleado;
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Movimientos — @emp?.Nombre @emp?.Apellido</h4>
    <a asp-action="Crear" asp-route-empleadoId="@emp?.Id" class="btn btn-success">&#43; Nuevo movimiento</a>
</div>
<div class="section-panel">
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr><th>Desde</th><th>Hasta</th><th>Puesto nuevo</th><th>Sucursal nueva</th><th>Motivo</th><th>Estado</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var m in Model)
                    {
                        <tr>
                            <td>@m.VigenciaDesde.ToString("dd/MM/yyyy")</td>
                            <td>@(m.VigenciaHasta.HasValue ? m.VigenciaHasta.Value.ToString("dd/MM/yyyy") : "—")</td>
                            <td>@m.PuestoNuevo?.Nombre</td>
                            <td>@m.SucursalNueva?.Nombre</td>
                            <td class="small">@m.Motivo</td>
                            <td>
                                @switch (m.Estado)
                                {
                                    case MrLee.Web.Models.EstadoMovimiento.VIGENTE:
                                        <span class="badge bg-success">Vigente</span>
                                        ; break;
                                    case MrLee.Web.Models.EstadoMovimiento.CERRADO:
                                        <span class="badge bg-secondary">Cerrado</span>
                                        ; break;
                                    case MrLee.Web.Models.EstadoMovimiento.ANULADO:
                                        <span class="badge bg-danger">Anulado</span>
                                        ; break;
                                }
                            </td>
                            <td class="text-end">
                                @if (m.Estado == MrLee.Web.Models.EstadoMovimiento.VIGENTE && m.VigenciaDesde > DateTime.Today)
                                {
                                    <a asp-action="Editar" asp-route-id="@m.Id" class="btn btn-sm btn-warning text-dark">✏️ Editar</a>
                                }
                                @if (m.Estado != MrLee.Web.Models.EstadoMovimiento.ANULADO)
                                {
                                    <a asp-action="Anular" asp-route-id="@m.Id" class="btn btn-sm btn-outline-danger">⛔ Anular</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <partial name="_EmptyMessage" model='new EmptyMessageVm
        {
            Title = "Sin movimientos",
            Message = "Todavia no hay movimientos laborales registrados para este empleado."
        }' />
    }
</div>
<div class="mt-3">
    <a asp-controller="Empleados" asp-action="Detalle" asp-route-id="@emp?.Id" class="btn btn-outline-secondary">← Volver</a>
</div>
