@model MrLee.Web.Controllers.LoginVm
@{
    ViewData["Title"] = "Iniciar sesion";
    Layout = "_Layout";
    var returnUrl = ViewBag.ReturnUrl as string;
}

<div class="login-shell">
    <div class="login-card shadow-lg">
        <div class="row g-0">
            <div class="col-lg-6">
                <div class="login-visual">
                    <div class="login-visual-content">
                        <div class="login-eyebrow">Bienvenido</div>
                        <h1 class="login-visual-title">Mr Lee System</h1>
                        <p class="login-visual-text mb-0">Accede al panel administrativo con la nueva identidad visual integrada desde el template.</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="login-panel">
                    <div class="mb-4">
                        <div class="login-eyebrow">Acceso interno</div>
                        <h2 class="login-title">Iniciar sesion</h2>
                        <p class="login-panel-copy mb-0">Este acceso corresponde al personal administrativo del sistema.</p>
                    </div>

                    <form asp-action="Login" asp-route-returnUrl="@returnUrl" method="post" class="login-form">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="All" class="alert alert-danger login-summary" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label login-label">Correo</label>
                            <input asp-for="Email" class="form-control login-input" type="email" autocomplete="username" placeholder="admin@mrlee.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-2">
                            <label asp-for="Password" class="form-label login-label">Contrasena</label>
                            <input asp-for="Password" class="form-control login-input" type="password" autocomplete="current-password" placeholder="********" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <button class="btn btn-primary w-100 login-submit" type="submit">Entrar como personal interno</button>

                        <div class="login-link-row">
                            <a asp-action="ForgotPassword">Olvido su contrasena?</a>
                        </div>
                    </form>

                    <div class="login-divider"></div>

                    <div class="login-secondary">
                        <div class="login-eyebrow">Sitio para clientes</div>
                        <p>Si vienes como cliente para consultar pedidos o administrar tu cuenta, entra aqui directamente.</p>

                        <div class="d-grid gap-3">
                            <a asp-controller="Portal" asp-action="Login" class="btn login-secondary-btn">Entrar como cliente</a>
                            <a asp-controller="Portal" asp-action="Registro" class="btn login-create-btn">Crear cuenta de cliente</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
