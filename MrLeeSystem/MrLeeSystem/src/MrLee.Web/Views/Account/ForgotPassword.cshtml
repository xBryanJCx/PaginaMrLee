@model MrLee.Web.Controllers.ForgotPasswordVm
@{
    ViewData["Title"] = "Recuperar acceso";
    Layout = "_Layout";
}

<div class="auth-simple-shell">
    <div class="auth-simple-card">
        <div class="login-eyebrow">Acceso interno</div>
        <h1 class="h2 mb-3">Recuperar acceso</h1>
        <p>Ingresa tu correo y el sistema enviara una contrasena temporal. Al iniciar sesion deberas cambiarla.</p>

        <form method="post" class="mt-4">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="alert alert-danger login-summary" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label login-label">Correo</label>
                <input asp-for="Email" class="form-control login-input" type="email" autocomplete="username" placeholder="admin@mrlee.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="d-grid gap-3 mt-4">
                <button type="submit" class="btn btn-primary login-submit">Enviar contrasena temporal</button>
                <a asp-action="Login" class="btn login-create-btn">Volver al inicio de sesion</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
