@model List<MrLee.Web.Models.CuentaBancaria>
@{
    ViewData["Title"] = "Cuentas bancarias";
    var emp = ViewBag.Empleado as MrLee.Web.Models.Empleado;
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Cuentas bancarias — @emp?.Nombre @emp?.Apellido</h4>
    <div class="d-flex gap-2">
        <a asp-action="Index" asp-route-empleadoId="@emp?.Id" class="btn btn-sm @(ViewBag.Estado == null ? "btn-primary" : "btn-outline-secondary")">Todas</a>
        <a asp-action="Index" asp-route-empleadoId="@emp?.Id" asp-route-estado="ACTIVA" class="btn btn-sm @(ViewBag.Estado?.ToString() == "ACTIVA" ? "btn-success" : "btn-outline-success")">Activas</a>
        <a asp-action="Index" asp-route-empleadoId="@emp?.Id" asp-route-estado="INACTIVA" class="btn btn-sm @(ViewBag.Estado?.ToString() == "INACTIVA" ? "btn-secondary" : "btn-outline-secondary")">Inactivas</a>
        <a asp-action="Crear" asp-route-empleadoId="@emp?.Id" class="btn btn-success">&#43; Nueva cuenta</a>
    </div>
</div>
<div class="section-panel">
    <table class="table table-hover align-middle mb-0">
        <thead>
            <tr><th>Banco</th><th>Tipo</th><th>Moneda</th><th>Número</th><th>IBAN</th><th>Principal</th><th>Estado</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td>@c.Banco</td>
                    <td>@c.TipoCuenta</td>
                    <td>@c.Moneda</td>
                    <td><code>@c.NumeroCuenta</code></td>
                    <td class="small text-muted">@c.Iban</td>
                    <td>@(c.EsPrincipal ? "⭐" : "")</td>
                    <td>
                        @if (c.Estado == MrLee.Web.Models.EstadoCuenta.ACTIVA)
                        {
                            <span class="badge bg-success">Activa</span>
                        }
                        else
                        {

                            <span class="badge bg-secondary">Inactiva</span>
                        }
                    </td>
                    <td class="text-end">
                        @if (c.Estado == MrLee.Web.Models.EstadoCuenta.ACTIVA)
                        {
                            <a asp-action="Editar" asp-route-id="@c.Id" class="btn btn-sm btn-warning text-dark">✏️ Editar</a>
                            <a asp-action="Inactivar" asp-route-id="@c.Id" class="btn btn-sm btn-outline-danger">⛔ Inactivar</a>
                        }
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="8" class="text-center text-muted py-4">Sin cuentas registradas.</td></tr>
            }
        </tbody>
    </table>
</div>
<div class="mt-3">
    <a asp-controller="Empleados" asp-action="Detalle" asp-route-id="@emp?.Id" class="btn btn-outline-secondary">← Volver</a>
</div>